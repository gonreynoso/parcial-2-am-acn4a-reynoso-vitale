<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_vertical">

        <!-- Brand row: logo circle + app name -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="36dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="S"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_logo_circle"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sprint"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvAuthTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_title_login"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Toggle link (subtitle position, left-aligned) -->
        <TextView
            android:id="@+id/tvToggleMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_toggle_register"
            android:textColor="@color/gris_texto"
            android:textSize="14sp"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Social buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGithub"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/auth_github"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:strokeColor="#3A3A3A"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/auth_google"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:strokeColor="#3A3A3A"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- OR separator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/auth_or"
                android:textAllCaps="true"
                android:textColor="@color/gris_texto"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

        </LinearLayout>

        <!-- Email label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <!-- Email input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false"
            app:boxStrokeColor="#3A3A3A"
            app:boxStrokeWidth="1dp"
            app:boxBackgroundColor="#111111">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:hint="usuario@email.com"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_texto" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <!-- Password input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:hintEnabled="false"
            app:boxStrokeColor="#3A3A3A"
            app:boxStrokeWidth="1dp"
            app:boxBackgroundColor="#111111"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:hint="••••••••"
                android:textColor="@color/white"
                android:textColorHint="@color/gris_texto" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvAuthError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/text_error"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Submit button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAuth"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="@string/auth_btn_login"
            android:textColor="@color/black"
            android:textSize="15sp"
            app:backgroundTint="@color/neon_green"
            app:cornerRadius="8dp" />

        <!-- Forgot password (below button, only in login mode) -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_forgot_password"
            android:textColor="@color/gris_texto"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Hidden: kept for Java compatibility -->
        <TextView
            android:id="@+id/tvAuthSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>

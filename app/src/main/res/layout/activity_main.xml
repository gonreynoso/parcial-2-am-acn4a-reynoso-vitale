<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/margen_principal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <TextView
            android:id="@+id/lblHoy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hoy"
            android:textColor="@color/white"
            android:textSize="@dimen/texto_titulo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/cardPasos"
            android:layout_width="@dimen/circulo_pasos_size"
            android:layout_height="@dimen/circulo_pasos_size"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/shape_circle"
            android:layout_marginTop="@dimen/espaciado_grande"
            app:layout_constraintTop_toBottomOf="@+id/lblHoy"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/txtPasos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pasos_iniciales"
                android:textColor="@color/fitbit_teal"
                android:textSize="@dimen/texto_numero_gigante"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pasos"
                android:textColor="@color/gris_texto" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutMetricas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/espaciado_grande"
            app:layout_constraintTop_toBottomOf="@id/cardPasos">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/padding_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="@dimen/size_icon"
                        android:layout_height="@dimen/size_icon"
                        android:src="@drawable/ic_location"
                        android:layout_marginBottom="8dp"
                        app:tint="@color/fitbit_teal"
                        android:contentDescription="@string/distancia_label" />
                    <TextView
                        android:id="@+id/txtDistancia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txtKm"
                        android:textColor="@color/white"
                        android:textSize="@dimen/texto_metrica" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/padding_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="@dimen/size_icon"
                        android:layout_height="@dimen/size_icon"
                        android:src="@drawable/ic_fire"
                        android:layout_marginBottom="8dp"
                        app:tint="@color/fitbit_teal"
                        android:contentDescription="@string/calorias_label" />
                    <TextView
                        android:id="@+id/txtCalorias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txtCal"
                        android:textColor="@color/white"
                        android:textSize="@dimen/texto_metrica" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/padding_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="@dimen/size_icon"
                        android:layout_height="@dimen/size_icon"
                        android:src="@drawable/ic_paso"
                        android:layout_marginBottom="8dp"
                        app:tint="@color/fitbit_teal"
                        android:contentDescription="@string/icono_de_pasos_desc"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/time"
                        android:textColor="@color/white"
                        android:textSize="@dimen/texto_metrica" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_card"
                    android:padding="@dimen/padding_card"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="@dimen/size_icon"
                        android:layout_height="@dimen/size_icon"
                        android:src="@drawable/ic_water"
                        android:layout_marginBottom="8dp"
                        app:tint="@color/fitbit_teal"
                        android:contentDescription="@string/icono_de_ubicacion_desc"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/litros"
                        android:textColor="@color/white"
                        android:textSize="@dimen/texto_metrica" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/contenedorDinamico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="@dimen/espaciado_grande"
            app:layout_constraintTop_toBottomOf="@id/layoutMetricas" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:backgroundTint="@color/bar_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:fitsSystemWindows="false"
        app:fabAlignmentMode="center"
        app:fabCradleVerticalOffset="10dp"
        app:contentInsetStart="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.BottomAppBar"
        app:contentInsetEnd="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="5">

            <LinearLayout
                android:id="@+id/navHome"
                style="@style/NavItem">
                <ImageView
                    android:src="@drawable/ic_home"
                    style="@style/NavIcon"/>
                <TextView
                    android:text="@string/inicio"
                    style="@style/NavLabel"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navHistory"
                style="@style/NavItem">
                <ImageView
                    android:src="@drawable/ic_history"
                    style="@style/NavIcon"/>
                <TextView
                    android:text="@string/historial"
                    style="@style/NavLabel"/>
            </LinearLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <LinearLayout
                android:id="@+id/navStats"
                style="@style/NavItem">
                <ImageView
                    android:src="@drawable/ic_article"
                    style="@style/NavIcon"/>
                <TextView
                    android:text="@string/stats"
                    style="@style/NavLabel"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfile"
                style="@style/NavItem">
                <ImageView
                    android:src="@drawable/ic_person"
                    style="@style/NavIcon"/>
                <TextView
                    android:text="@string/perfil"
                    style="@style/NavLabel"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.bottomappbar.BottomAppBar>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRun"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="10dp"
        android:src="@drawable/ic_sprint"
        android:scaleType="centerInside"
        android:contentDescription="@string/iniciar_carrera"
        app:backgroundTint="@color/neon_green"
        app:tint="#000000"
        app:borderWidth="0dp"
        app:maxImageSize="36dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Fab"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>